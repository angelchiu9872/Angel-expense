// --- CSV 解析工具 ---
const parseCSV = (csvText) => {
  const lines = csvText.split(/\r?\n/).filter(line => line.trim() !== "");
  if (lines.length < 2) return [];

  const headers = lines[0].split(',').map(h => h.trim().replace(/^"|"$/g, ''));
  const dateIdx = headers.findIndex(h => h.includes('時間戳記'));
  const amountIdx = headers.findIndex(h => h.includes('費用'));
  const categoryIdx = headers.findIndex(h => h.includes('類別'));

  const safeDateIdx = dateIdx !== -1 ? dateIdx : 0;
  const safeAmountIdx = amountIdx !== -1 ? amountIdx : 1;
  const safeCatIdx = categoryIdx !== -1 ? categoryIdx : 2;

  const parsedData = [];
  for (let i = 1; i < lines.length; i++) {
    const row = lines[i].split(/,(?=(?:(?:[^"]*"){2})*[^"]*$)/).map(item => item.replace(/^"|"$/g, '').trim());
    if (row.length > Math.max(safeDateIdx, safeAmountIdx, safeCatIdx)) {
      const rawDate = row[safeDateIdx];
      const amountStr = row[safeAmountIdx] || "0";
      const category = row[safeCatIdx] || '其他';
      const amount = parseFloat(amountStr.replace(/[^0-9.-]+/g, '')) || 0;

      let dateObj = new Date(rawDate);
      if (isNaN(dateObj.getTime()) && rawDate.includes('/')) {
        const parts = rawDate.split(' ')[0].split('/');
        if (parts.length === 3) {
          dateObj = parts[0].length === 4 ? new Date(parts[0], parts[1] - 1, parts[2]) : new Date(parts[2], parts[0] - 1, parts[1]);
        }
      }

      if (!isNaN(dateObj.getTime())) {
        parsedData.push({
          id: i,
          date: dateObj.toISOString().split('T')[0],
          month: `${dateObj.getFullYear()}-${String(dateObj.getMonth() + 1).padStart(2, '0')}`,
          category: category,
          amount: Math.abs(amount) 
        });
      }
    }
  }
  return parsedData;
};

// ==========================================
// 主要 App 元件
// ==========================================
export default function App() {
  const [activeTab, setActiveTab] = useState('input');
  const [expenses, setExpenses] = useState([]);
  const [loading, setLoading] = useState(true);
  const [errorMsg, setErrorMsg] = useState('');
  const [lastUpdated, setLastUpdated] = useState(null);

  const fetchExpenses = async () => {
    setLoading(true);
    try {
      const url = `https://docs.google.com/spreadsheets/d/e/2PACX-1vRfdXmG5deMAoGDbfQbftAZiXCIHhDlRbqlkqBcRAGZ8lVSP6YD5UuWKN5sCppAQqE16wEy-AaCvQmA/pub?gid=107014608&single=true&output=csv&cachebust=${Date.now()}`;
      const response = await fetch(url);
      const csvText = await response.text();
      const data = parseCSV(csvText);
      setExpenses(data);
      setLastUpdated(new Date().toLocaleTimeString());
    } catch (error) {
      setErrorMsg("讀取失敗，請確認網路連線或發佈網址。");
    } finally {
      setLoading(false);
    }
  };

  useEffect(() => { fetchExpenses(); }, []);

  return (
    <div className="min-h-screen flex flex-col md:flex-row font-sans" style={{ backgroundColor: theme.bg, color: theme.textDark }}>
      {/* 側邊導覽 */}
      <nav className="md:w-64 md:h-screen shadow-xl flex-shrink-0 flex flex-col z-10 sticky top-0" style={{ backgroundColor: theme.primary }}>
        <div className="p-8 text-center md:text-left">
          <h1 className="text-2xl font-black tracking-tighter" style={{ color: theme.textDark }}>精緻記帳</h1>
          <div className="h-1 w-12 bg-white/40 mt-2 rounded-full hidden md:block" />
        </div>
        
        <div className="hidden md:flex flex-col flex-1 px-4 gap-3 mt-4">
          <NavButton icon={<PenSquare size={20} />} label="記帳表單" isActive={activeTab === 'input'} onClick={() => setActiveTab('input')} />
          <NavButton icon={<LayoutDashboard size={20} />} label="消費總覽" isActive={activeTab === 'overview'} onClick={() => setActiveTab('overview')} />
          <NavButton icon={<Wallet size={20} />} label="預算追蹤" isActive={activeTab === 'budget'} onClick={() => setActiveTab('budget')} />
          <NavButton icon={<Calculator size={20} />} label="財務結算" isActive={activeTab === 'settle'} onClick={() => setActiveTab('settle')} />
          
          <div className="mt-auto mb-8 px-4 py-3 bg-white/20 rounded-2xl">
            <button onClick={fetchExpenses} className="flex items-center gap-2 text-xs font-bold w-full">
              <RefreshCw size={14} className={loading ? 'animate-spin' : ''} />
              {loading ? '同步中...' : `同步於 ${lastUpdated || '--:--'}`}
            </button>
          </div>
        </div>
      </nav>

      {/* 內容區 */}
      <main className="flex-1 overflow-y-auto">
        <div className="max-w-6xl mx-auto p-4 md:p-10 pb-24 md:pb-10">
          {errorMsg && <div className="bg-red-100 text-red-700 p-4 rounded-xl mb-6 flex items-center gap-2"><AlertCircle size={18}/>{errorMsg}</div>}
          
          {activeTab === 'input' && <InputPage />}
          {activeTab === 'overview' && (loading ? <LoadingOverlay /> : <OverviewPage expenses={expenses} />)}
          {activeTab === 'budget' && (loading ? <LoadingOverlay /> : <BudgetPage expenses={expenses} />)}
          {activeTab === 'settle' && (loading ? <LoadingOverlay /> : <SettlePage expenses={expenses} />)}
        </div>
      </main>

      {/* 行動版底部導覽 */}
      <nav className="md:hidden fixed bottom-4 left-4 right-4 h-16 shadow-2xl rounded-2xl flex justify-around items-center z-20 overflow-hidden" style={{ backgroundColor: theme.primary }}>
        <MobileNavButton icon={<PenSquare size={22} />} isActive={activeTab === 'input'} onClick={() => setActiveTab('input')} />
        <MobileNavButton icon={<LayoutDashboard size={22} />} isActive={activeTab === 'overview'} onClick={() => setActiveTab('overview')} />
        <MobileNavButton icon={<Wallet size={22} />} isActive={activeTab === 'budget'} onClick={() => setActiveTab('budget')} />
        <MobileNavButton icon={<Calculator size={22} />} isActive={activeTab === 'settle'} onClick={() => setActiveTab('settle')} />
      </nav>
    </div>
  );
}

